%% ASEN 3802 - Part 1 - Main
% Has user input a 4-digit NACA airfoil converts each digit to its appropriate value and plots the provided airfoil, adding a camber line if necessary.
%
% Author: Lane Hollis
% Collaborators: Colton Firster, Josh Bumann, Clara Eide
% Date: 4/7/2026

clc;
clear;
close all; 

% Prompt the user to input a 4-digit NACA airfoil name 
naca = input('Enter a 4-digit NACA airfoil name: ','s');

% Extract the airfoil characteristics from the NACA name
m = str2num(naca(1))/100;
p = str2num(naca(2))/10; 
t = str2num(naca(3:4))/100; 
N = 50; % number of panels
c = 10; % meters


[x_b, y_b, x, y_c] = NACA_Airfoils(m, p, t, c, N);

% Plot the airfoil shape
figure;
plot(x_b, y_b, 'b-', 'LineWidth', 2);
hold on;
if m > 0
    plot(x, y_c, 'g-', 'LineWidth', 2);
end
axis equal;
xlabel('x/c');
ylabel('y/c');
title(['NACA ' naca ' Airfoil Shape']);
grid on;
